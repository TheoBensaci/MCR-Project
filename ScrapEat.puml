@startuml
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
left to right direction

package "Entry / Scene flow" {
  class Main
  class MainSceen
  class CameraPlacement
  class ShopKeeper
  class CameraShake
  class DebugSceen
}

package "UI" {
  class UiManager
  class UiScreen
  class UiAction
  class UiActionShop
  class UiActionBet
  class UiActionScore
  class Card
  class MoneyText
  class IconsLib
}

package "Arena" {
  class ArenaManager
  class RunResume
  class Hazard
  class HazardObject
}

package "Item system" {
  interface Item
  class BaseItem
  abstract class AbstractItemDecorator
  class ItemFactory
  class ItemRenderInfo
  class ItemWrapper

  class ModelDecorator
  class SpeedDecorator
  class AccelerationDecorator
  class TpDecorator
  class LootBoxDecorator
  class HealDecorator
  class InvicibilityDecorator
  class GreedyDecorator
  class SpikeDecorator
  class PoisonDecorator
  class CurseDecorator
  class RandomDecorator

  enum ItemTag
}

package "Powerups / bets" {
  abstract class PowerUp
  class PowerUpHpUp
  class PowerBlockHit
  class PowerBaseDecorator

  abstract class Bet
  class BetNDecorator
  class BetNoDamage
}

package "Player" {
  class Player
  enum DamageType
}

package "Utilities" {
  class UtilsRandom
  class MathUtils
  class OtherUtils
}

Main --> MainSceen
MainSceen --> ArenaManager
MainSceen --> ShopKeeper
MainSceen --> UiManager
MainSceen --> CameraPlacement

ShopKeeper --> UiManager
CameraPlacement --> ShopKeeper

UiManager o-- UiScreen
UiScreen o-- UiAction
UiActionShop --|> UiAction
UiActionBet --|> UiAction
UiActionScore --|> UiAction
UiActionShop --> Card
UiActionBet --> Card
UiActionShop --> PowerUp
UiActionBet --> Bet

UiActionScore --> MainSceen

ArenaManager --> MainSceen
ArenaManager --> Player
ArenaManager --> RunResume
ArenaManager --> Bet
ArenaManager --> ItemWrapper
ArenaManager --> HazardObject
ArenaManager ..> ItemFactory

RunResume --> Item

Hazard --> Player
HazardObject --> Player
HazardObject --> DamageType

MainSceen --> ShopKeeper
MainSceen --> ArenaManager
MainSceen --> UiManager

Player --> ArenaManager
Player --> MoneyText
Player --> DamageType
Player --> Item
Player --> CameraShake

AbstractItemDecorator o-- Item : wraps
BaseItem ..|> Item
AbstractItemDecorator ..|> Item

ModelDecorator --|> AbstractItemDecorator
SpeedDecorator --|> AbstractItemDecorator
AccelerationDecorator --|> SpeedDecorator
TpDecorator --|> AbstractItemDecorator
LootBoxDecorator --|> AbstractItemDecorator
HealDecorator --|> AbstractItemDecorator
InvicibilityDecorator --|> AbstractItemDecorator
GreedyDecorator --|> AbstractItemDecorator
SpikeDecorator --|> AbstractItemDecorator
PoisonDecorator --|> AbstractItemDecorator
CurseDecorator --|> AbstractItemDecorator
RandomDecorator --|> AbstractItemDecorator

ItemFactory ..> BaseItem
ItemFactory ..> ModelDecorator
ItemFactory ..> AccelerationDecorator
ItemFactory ..> TpDecorator
ItemFactory ..> LootBoxDecorator
ItemFactory ..> SpeedDecorator
ItemFactory ..> HealDecorator
ItemFactory ..> InvicibilityDecorator
ItemFactory ..> GreedyDecorator
ItemFactory ..> SpikeDecorator
ItemFactory ..> PoisonDecorator
ItemFactory ..> CurseDecorator
ItemFactory ..> RandomDecorator

ItemWrapper --> Item
ItemWrapper --> ItemRenderInfo
ItemWrapper --> IconsLib

PowerUp <|-- PowerUpHpUp
PowerUp <|-- PowerBlockHit
PowerUp <|-- PowerBaseDecorator

Bet <|-- BetNDecorator
Bet <|-- BetNoDamage

PowerUpHpUp --> ArenaManager
PowerBlockHit --> ArenaManager
PowerBaseDecorator --> ArenaManager

BetNDecorator --> ArenaManager
BetNoDamage --> ArenaManager

UiActionShop --> MainSceen
UiActionBet --> MainSceen

CameraShake --|> Camera2D
Main --|> Node
MainSceen --|> Node2D
ShopKeeper --|> Node2D
UiManager --|> Node
UiScreen --|> Control
UiAction --|> Node
Card --|> Button
MoneyText --|> Label
IconsLib --|> Node2D
ArenaManager --|> Node
Hazard --|> Node2D
HazardObject --|> Node2D
Player --|> CharacterBody2D
ItemWrapper --|> Node2D
DebugSceen --|> Node2D

note right of MainSceen
The main scene links the arena,
the shopkeeper, the UI manager,
and the camera placements.
end note

note right of ItemFactory
Creates items by starting from BaseItem
and applying decorators by name.
end note

@enduml